---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import GridBackground from "../ui/GridBackground.astro";
import "../../styles/global.css";
// ZH-specific styles are imported unconditionally — every rule inside is
// scoped under `html[lang="zh"]`, so EN pages never apply any of it, and
// the CJK woff2 files only load when glyphs actually require them.
import "../../styles/zh.css";
import { type Locale, defaultLocale, t, toggleLocalePath } from "../../lib/i18n";

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  ogImage?: string;
  noFooter?: boolean;
}

const {
  title,
  description,
  lang = defaultLocale,
  ogImage = "/assets/brand/banner.jpg",
  noFooter = false,
} = Astro.props;

const siteTitle = t(lang, "site.title");
const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const pageDescription = description ?? t(lang, "site.description");
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Compute absolute URLs for each locale variant of this page
const enUrl = new URL(toggleLocalePath(Astro.url.pathname, "en"), Astro.site).href;
const zhUrl = new URL(toggleLocalePath(Astro.url.pathname, "zh"), Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    {/* No-FOUC theme init — MUST run before any stylesheet + before paint.
        Stored values: "light" / "dark" / missing.
        Missing = follow OS preference; "light"/"dark" = explicit override. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("ts-theme");
          if (stored === "dark") {
            document.documentElement.dataset.theme = "dark";
          } else if (stored === "light") {
            document.documentElement.dataset.theme = "light";
          } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.dataset.theme = "dark";
          }
        } catch (e) {}
      })();
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Alternate language variants (for SEO) -->
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:url" content={canonicalUrl.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <GridBackground />
    <Header locale={lang} />
    <main>
      <slot />
    </main>
    {!noFooter && <Footer locale={lang} />}
  </body>
</html>
