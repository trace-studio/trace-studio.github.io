---
interface Props {
  density?: number;
  opacity?: number;
  variant?: "dots" | "cross" | "matrix";
}

const { density = 32, opacity = 0.2, variant = "cross" } = Astro.props;
---

<div class="grid-background" aria-hidden="true">
  <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern
        id={`grid-${variant}`}
        width={density}
        height={density}
        patternUnits="userSpaceOnUse"
      >
        {variant === "dots" && (
          <circle cx={density / 2} cy={density / 2} r="1" fill="currentColor" />
        )}
        {variant === "cross" && (
          <>
            <line
              x1={density / 2}
              y1={density / 2 - 3}
              x2={density / 2}
              y2={density / 2 + 3}
              stroke="currentColor"
              stroke-width="0.5"
            />
            <line
              x1={density / 2 - 3}
              y1={density / 2}
              x2={density / 2 + 3}
              y2={density / 2}
              stroke="currentColor"
              stroke-width="0.5"
            />
          </>
        )}
        {variant === "matrix" && (
          <>
            <line
              x1="0" y1="0"
              x2={density} y2="0"
              stroke="currentColor"
              stroke-width="0.5"
            />
            <line
              x1="0" y1="0"
              x2="0" y2={density}
              stroke="currentColor"
              stroke-width="0.5"
            />
          </>
        )}
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#grid-${variant})`} />
  </svg>
</div>

<style define:vars={{ opacity: String(opacity) }}>
  .grid-background {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    color: var(--c-ink);
    opacity: var(--opacity);
  }

  .grid-background svg {
    width: 100%;
    height: 100%;
  }
</style>
